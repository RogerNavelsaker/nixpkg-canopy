{
  "name": "@rona/nix-canopy-cli",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "show-manifest": "bun --eval \"console.log(await Bun.file('nix/package-manifest.json').text())\"",
    "sync:manifest": "bun run scripts/sync-from-npm.ts",
    "postinstall": "bunx bun2nix -o bun.nix"
  },
  "dependencies": {
    "@os-eco/canopy-cli": "0.2.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "bun2nix": "2.0.8"
  }
}
